# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MySQL variables used by src/server.ts
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=essentielle_sante

# Set true only if your host requires SSL (typical on managed hosting)
DB_SSL=false

# TOKEN_SECRET: Secret used to sign auth tokens (HMAC).
# Must be a strong random string in production.
# If you keep the default, tokens are signed with a dev secret.
TOKEN_SECRET="MY_TOKEN_SECRET"

# Compatibility aliases accepted by the server for shared hosting panels.
# You can use these instead of the DB_* / TOKEN_SECRET names if your host UI
# is already configured that way.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=essentielle_sante
JWT_SECRET="MY_TOKEN_SECRET"
